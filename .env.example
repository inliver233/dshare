PORT=12399
ADDR=:8080
APP_BASE_URL=http://localhost:12399
COOKIE_SECURE=false

# Discord Developer Portal callback:
# http://localhost:12399/api/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URL=

# Local fallback admin login for /admin. Change both values before production use.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Comma-separated Discord numeric IDs promoted to admin after login.
ADMIN_DISCORD_IDS=

# Existing upstream services.
NEW_API_BASE_URL=http://new-api:3000
NEW_API_KEY=sk-your-new-api-token
DS2API_BASE_URL=http://host.docker.internal:5001
DS2API_ADMIN_KEY=change-me
DS2API_AUTO_PROXY_ENABLED=true
DS2API_AUTO_PROXY_TYPE=socks5
DS2API_AUTO_PROXY_HOST=127.0.0.1
DS2API_AUTO_PROXY_PORT=21345
DS2API_AUTO_PROXY_USERNAME_TEMPLATE=Default.{local}
DS2API_AUTO_PROXY_PASSWORD=
DS2API_AUTO_PROXY_NAME_TEMPLATE=resin-{local}

DEFAULT_REQUESTS_PER_MINUTE=5
DEFAULT_REQUESTS_PER_DAY=2500
DEFAULT_MAX_CONCURRENT=4
DS2API_VALIDATE_WORKERS=3
SESSION_DAYS=30
STREAM_KEEPALIVE_AFTER_SECONDS=20
STREAM_KEEPALIVE_INTERVAL_SECONDS=10
